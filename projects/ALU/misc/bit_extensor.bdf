(header "graphic" (version "1.4"))
(pin
	(input)
	(rect 200 96 368 112)
	(text "INPUT" (rect 125 0 153 10)(font "Arial" (font_size 6)))
	(text "In[4..0]" (rect 5 0 43 11)(font "Arial" ))
	(pt 168 8)
	(drawing
		(line (pt 84 12)(pt 109 12))
		(line (pt 84 4)(pt 109 4))
		(line (pt 113 8)(pt 168 8))
		(line (pt 84 12)(pt 84 4))
		(line (pt 109 4)(pt 113 8))
		(line (pt 109 12)(pt 113 8))
	)
	(text "VCC" (rect 128 7 148 17)(font "Arial" (font_size 6)))
)
(pin
	(output)
	(rect 680 96 856 112)
	(text "OUTPUT" (rect 1 0 39 10)(font "Arial" (font_size 6)))
	(text "Out[5..0]" (rect 90 0 138 11)(font "Arial" ))
	(pt 0 8)
	(drawing
		(line (pt 0 8)(pt 52 8))
		(line (pt 52 4)(pt 78 4))
		(line (pt 52 12)(pt 78 12))
		(line (pt 52 12)(pt 52 4))
		(line (pt 78 4)(pt 82 8))
		(line (pt 82 8)(pt 78 12))
		(line (pt 78 12)(pt 82 8))
	)
)
(symbol
	(rect 512 168 544 200)
	(text "GND" (rect 8 16 30 26)(font "Arial" (font_size 6)))
	(text "inst" (rect 3 21 23 32)(font "Arial" )(invisible))
	(port
		(pt 16 0)
		(output)
		(text "1" (rect 18 0 25 11)(font "Courier New" (bold))(invisible))
		(text "1" (rect 18 0 25 11)(font "Courier New" (bold))(invisible))
		(line (pt 16 8)(pt 16 0))
	)
	(drawing
		(line (pt 8 8)(pt 16 16))
		(line (pt 16 16)(pt 24 8))
		(line (pt 8 8)(pt 24 8))
	)
)
(connector
	(text "GND" (rect 511 132 522 154)(font "DejaVu Sans Condensed" )(vertical))
	(pt 528 104)
	(pt 528 168)
)
(connector
	(text "In[4], In[3..0]" (rect 412 88 475 99)(font "DejaVu Sans Condensed" ))
	(pt 368 104)
	(pt 528 104)
	(bus)
)
(connector
	(text "In[4], GND, In[3..0]" (rect 566 88 656 99)(font "DejaVu Sans Condensed" ))
	(pt 528 104)
	(pt 680 104)
	(bus)
)
(junction (pt 528 104))
